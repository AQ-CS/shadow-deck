{
  "name": "shadow-deck",
  "description": "Multi-Provider Council of Agents for surgical code refactoring.",
  "author": "ShadowDeck Team",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "react:dev": "vite",
    "electron:dev": "node scripts/electron-dev.js",
    "build": "vite build",
    "build:exe": "electron-builder --win",
    "preview": "vite preview",
    "setup": "node scripts/install-ai.js"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "lowdb": "^7.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@google/generative-ai": "^0.24.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@splinetool/react-spline": "^4.1.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.20",
    "framer-motion": "^12.34.5",
    "globals": "^16.5.0",
    "lucide-react": "^0.576.0",
    "motion": "^12.34.5",
    "postcss": "^8.5.8",
    "puppeteer": "^24.38.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-live": "^4.1.8",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19",
    "three": "^0.183.2",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.shadowdeck.app",
    "productName": "ShadowDeck",
    "win": {
      "target": "nsis",
      "icon": "public/sdeck.png"
    },
    "directories": {
      "output": "release"
    },
    "npmArgs": [
      "--omit=dev"
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ]
  }
}
