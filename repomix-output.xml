// electron/store.js — Persistent JSON file storage for ShadowDeck
// ═══════════════════════════════════════════════════════════════════════════
//  v5: Multi-Provider Hybrid Engine
//
//  NEW in this version:
//    - providers: { groqApiKey, githubModelsApiKey, ollamaUrl }
//    - usage:     { groqDailyUsage, githubDailyUsage, usageResetDate }
//    - Daily usage auto-resets at midnight local time (checked on every read)
// ═══════════════════════════════════════════════════════════════════════════

import fs from 'fs';
import path from 'path';

// ── Helpers ───────────────────────────────────────────────────────────────────

/** Returns today's date as YYYY-MM-DD (local time). */
function getTodayDateStr() {
    const d = new Date();
    return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
}

// ── Schema Defaults ────────────────────────────────────────────────────────────

const DEFAULT_CONFIG = {
    mode: 'hybrid',             // 'local' | 'hybrid' | 'cloud'
    activeProfile: 'beast',     // 'beast' | 'operative' | 'cloud'

    // ── Legacy API Keys (kept for backwards compat) ──
    apiKeys: {
        gemini: '',
        openai: '',
    },

    // ── Multi-Provider BYOK Keys ─────────────────────
    providers: {
        groqApiKey: '',                        // Groq — 14,400 RPD free tier
        githubModelsApiKey: '',                        // GitHub Models — 50–150 RPD
        ollamaUrl: 'http://localhost:11434',  // Local Ollama instance
    },

    // ── UI Preferences ───────────────────────────────
    ui: {
        accentColor: '#14b8a6',
        background: 'pulse',
        glareShield: false,
    },

    // ── Privacy ──────────────────────────────────────
    incognito: false,

    // ── Daily Usage Counters (auto-reset at midnight) ─
    usage: {
        groqDailyUsage: 0,
        githubDailyUsage: 0,
        usageResetDate: '',  // YYYY-MM-DD — compared against getTodayDateStr()
    },
};

// ── Module State ──────────────────────────────────────────────────────────────

let userDataPath = '';
let configCache = null;
let historyCache = null;

function configPath() { return path.join(userDataPath, 'config.json'); }
function historyPath() { return path.join(userDataPath, 'history.json'); }

// ── JSON I/O ──────────────────────────────────────────────────────────────────

function readJSON(filePath, fallback) {
    try {
        if (fs.existsSync(filePath)) {
            return JSON.parse(fs.readFileSync(filePath, 'utf8'));
        }
    } catch (err) {
        console.error(`[STORE] Failed to read ${filePath}:`, err.message);
    }
    return fallback;
}

function writeJSON(filePath, data) {
    try {
        fs.mkdirSync(path.dirname(filePath), { recursive: true });
        fs.writeFileSync(filePath, JSON.stringify(data, null, 2), 'utf8');
    } catch (err) {
        console.error(`[STORE] Failed to write ${filePath}:`, err.message);
    }
}

// ── Daily Usage Reset ─────────────────────────────────────────────────────────
//
// Called on every getConfig(). If the stored reset date differs from today,
// counters are zeroed and the new date is written to disk.
// This is pure local-time logic — no network calls required.

function applyUsageReset(config) {
    const today = getTodayDateStr();
    const storedDate = config.usage?.usageResetDate || '';

    if (storedDate === today) return config; // nothing to do

    console.log(`[STORE] 🔄 Daily usage reset: ${storedDate} → ${today}`);

    const resetUsage = {
        groqDailyUsage: 0,
        githubDailyUsage: 0,
        usageResetDate: today,
    };

    const updated = { ...config, usage: resetUsage };
    writeJSON(configPath(), updated);
    configCache = updated;
    return updated;
}

// ── Deep Merge ────────────────────────────────────────────────────────────────

function deepMergeConfig(base, incoming) {
    return {
        ...base,
        ...incoming,
        apiKeys: { ...base.apiKeys, ...(incoming?.apiKeys || {}) },
        providers: { ...base.providers, ...(incoming?.providers || {}) },
        ui: { ...base.ui, ...(incoming?.ui || {}) },
        usage: { ...base.usage, ...(incoming?.usage || {}) },
    };
}

// ── Public API ─────────────────────────────────────────────────────────────────

export function initStore(dataPath) {
    userDataPath = dataPath;
    console.log(`[STORE] Data directory: ${userDataPath}`);
    configCache = readJSON(configPath(), { ...DEFAULT_CONFIG });
    historyCache = readJSON(historyPath(), []);
}

export function getConfig() {
    if (!configCache) configCache = readJSON(configPath(), { ...DEFAULT_CONFIG });
    // Merge against defaults to fill any missing keys from older configs
    let merged = deepMergeConfig(DEFAULT_CONFIG, configCache || {});
    // Apply midnight reset if needed
    merged = applyUsageReset(merged);
    return merged;
}

export function setConfig(patch) {
    const current = getConfig();
    const updated = deepMergeConfig(current, patch);
    configCache = updated;
    writeJSON(configPath(), configCache);
    return configCache;
}

// ── Usage Counter API ──────────────────────────────────────────────────────────
//
// Called by the Express bridge after a successful AI dispatch.
// Handles the midnight-reset guard internally so callers don't need to.

export function incrementUsage(provider) {
    const config = getConfig(); // this also applies the daily reset
    const usage = { ...config.usage };
    const today = getTodayDateStr();

    // Safety: re-check the date in case getConfig reset happened concurrently
    if (usage.usageResetDate !== today) {
        usage.groqDailyUsage = 0;
        usage.githubDailyUsage = 0;
        usage.usageResetDate = today;
    }

    if (provider === 'groq') usage.groqDailyUsage = (usage.groqDailyUsage || 0) + 1;
    if (provider === 'github') usage.githubDailyUsage = (usage.githubDailyUsage || 0) + 1;

    console.log(`[STORE] 📊 Usage — Groq: ${usage.groqDailyUsage}/14400 | GitHub: ${usage.githubDailyUsage}/50`);

    return setConfig({ usage });
}

export function getUsage() {
    const config = getConfig(); // triggers midnight reset if needed
    return config.usage || DEFAULT_CONFIG.usage;
}

// ── History API ────────────────────────────────────────────────────────────────

export function getHistory() {
    if (!historyCache) historyCache = readJSON(historyPath(), []);
    return historyCache || [];
}

export function saveSession(sessionData) {
    if (!historyCache) historyCache = readJSON(historyPath(), []);
    if (!historyCache) historyCache = [];

    const existingIndex = historyCache.findIndex(s => s.id === sessionData.id);
    const record = {
        ...sessionData,
        timestamp: sessionData.timestamp || new Date().toISOString(),
    };

    if (existingIndex >= 0) {
        historyCache[existingIndex] = record;
    } else {
        historyCache.unshift(record);
    }

    // Cap at 50 sessions
    if (historyCache.length > 50) historyCache = historyCache.slice(0, 50);
    writeJSON(historyPath(), historyCache);
    return record;
}

// Legacy alias kept for bridge.js compatibility
export function appendHistory(entry) {
    return saveSession(entry);
}

export function clearHistory() {
    historyCache = [];
    try { writeJSON(historyPath(), historyCache); } catch (err) { console.error(err); }
}
</file>

