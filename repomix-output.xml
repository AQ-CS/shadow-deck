@tailwind base;
@tailwind components;
@tailwind utilities;

/* ══════════════════════════════════════════════
   SHADOW_DECK — Void Black Base Layer
   ══════════════════════════════════════════════ */

*,
*::before,
*::after {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html,
body,
#root {
  height: 100%;
  width: 100%;
  overflow: hidden;
}

body {
  background-color: #000;
  color: #a1a1aa;
  /* zinc-400 */
  font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
  font-size: 13px;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* ── Scrollbar: Stealth ── */
::-webkit-scrollbar {
  width: 4px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 2px;
}

::-webkit-scrollbar-thumb:hover {
  background: rgba(255, 255, 255, 0.15);
}

/* ── Selection ── */
::selection {
  background: rgba(20, 184, 166, 0.3);
  color: #fff;
}

/* ── CRT Scanline Overlay ── */
.crt-overlay {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 9999;
  background: repeating-linear-gradient(0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.03) 2px,
      rgba(0, 0, 0, 0.03) 4px);
  mix-blend-mode: multiply;
}

/* ── Noise Texture Overlay ── */
.noise-overlay {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 9998;
  opacity: 0.025;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  background-repeat: repeat;
  background-size: 128px 128px;
}

/* ── Glow Utilities ── */
.glow-teal {
  box-shadow: 0 0 15px rgba(20, 184, 166, 0.15), 0 0 40px rgba(20, 184, 166, 0.05);
}

.glow-teal-sm {
  box-shadow: 0 0 8px rgba(20, 184, 166, 0.1), 0 0 20px rgba(20, 184, 166, 0.03);
}

.text-glow-teal {
  text-shadow: 0 0 10px rgba(20, 184, 166, 0.4), 0 0 30px rgba(20, 184, 166, 0.1);
}

/* ── Glass Panel ── */
.glass-panel {
  background: rgba(9, 9, 11, 0.6);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(255, 255, 255, 0.06);
}

.glass-panel-strong {
  background: rgba(9, 9, 11, 0.8);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1px solid rgba(255, 255, 255, 0.08);
}

/* ── Keyframes ── */
@keyframes pulse-glow {

  0%,
  100% {
    opacity: 1;
    box-shadow: 0 0 4px rgba(20, 184, 166, 0.6);
  }

  50% {
    opacity: 0.5;
    box-shadow: 0 0 12px rgba(20, 184, 166, 0.9);
  }
}

@keyframes flicker {

  0%,
  100% {
    opacity: 1;
  }

  92% {
    opacity: 1;
  }

  93% {
    opacity: 0.8;
  }

  94% {
    opacity: 1;
  }

  96% {
    opacity: 0.9;
  }

  97% {
    opacity: 1;
  }
}

.animate-flicker {
  animation: flicker 4s infinite;
}

@keyframes glitch {

  0%,
  100% {
    transform: translateX(0);
  }

  10% {
    transform: translateX(-2px);
  }

  20% {
    transform: translateX(2px);
  }

  30% {
    transform: translateX(-1px);
  }

  40% {
    transform: translateX(1px);
  }

  50% {
    transform: translateX(0);
  }
}

.animate-glitch {
  animation: glitch 0.3s ease-in-out 1;
}
